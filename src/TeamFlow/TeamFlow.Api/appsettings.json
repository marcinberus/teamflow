{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=TeamFlow;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowMinutes": 1
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Secret": "dev-only-secret-replace-via-env-in-production!!",
    "Issuer": "teamflow",
    "Audience": "teamflow",
    "ExpiryMinutes": 60
  }
}

